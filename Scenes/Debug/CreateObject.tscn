[gd_scene format=3 uid="uid://bebrrymkrf6km"]

[ext_resource type="Texture2D" uid="uid://c31da10fm151r" path="res://icon.png" id="1_inqh2"]

[sub_resource type="GDScript" id="GDScript_ikbfr"]
resource_name = "Handler"
script/source = "extends Control

var defimg = \"res://icon.png\"
var imglocation := \"res://icon.png\"

func _on_open_pressed() -> void:
	$OpenDialog.popup_centered()
	Input.mouse_mode = Input.MOUSE_MODE_CONFINED

func _on_open_dialog_file_selected(path: String) -> void:
	Input.mouse_mode = Input.MOUSE_MODE_HIDDEN
	var f = FileAccess.open(path, FileAccess.READ)
	var js = JSON.parse_string(f.get_as_text())
	
	%Name.text = js.get(\"n\")
	%Description.text = js.get(\"d\")
	imglocation = js.get(\"i\")
	%Image.icon = load(imglocation)
	%Source.text = js.get(\"s\")
	
	print(\"Success open\")

func _on_export_file_selected(path: String) -> void:
	Input.mouse_mode = Input.MOUSE_MODE_HIDDEN
	var f = FileAccess.open(path, FileAccess.WRITE)
	var dict = {
		n = %Name.text,
		d = %Description.text,
		i = imglocation,
		s = %Source.text
	}
	print(dict)
	var js = JSON.stringify(dict)
	print(js)
	f.store_string(js)

func _on_export_pressed() -> void:
	%ExportDialog.popup_centered()
	Input.mouse_mode = Input.MOUSE_MODE_CONFINED

func _on_reset_pressed() -> void:
	%Name.text = \"\"
	%Description.text = \"\"
	%Image.icon = load(defimg)
	%Source.text = \"\"
	imglocation = defimg

func _on_image_pressed() -> void:
	%OpenImageDialog.popup_centered()
	Input.mouse_mode = Input.MOUSE_MODE_CONFINED

func _on_open_image_dialog_file_selected(path: String) -> void:
	%Image.icon = load(path)
	imglocation = path
	print(\"New icon: \"+path)
	Input.mouse_mode = Input.MOUSE_MODE_HIDDEN

func _on_open_link_pressed() -> void:
	#var results = []
	#OS.execute(\"CMD.exe\", [\"/c\", %Source.text], results)
	#print(%Source.text, results)
	OS.shell_open(%Source.text)
"

